            "settings": {
                "foreground": "#F0B19E"
            }
        },
        {
            "name": "Attributes",
            "scope": ["entity.other.attribute-name"],
            "settings": {
                "foreground": "#E2463F"
            }
        },
        {
            "name": "HTML Attributes",
            "scope": [
